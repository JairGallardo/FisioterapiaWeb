<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Centro Bienestar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f4f7f9;
            display: flex;
            min-height: 100vh;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
        }

        .sidebar {
            width: 280px;
            background-color: #6a96b3;
            color: white;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 1000;
        }

        .nav-link {
            color: white;
            opacity: 0.8;
            padding: 15px 30px;
            transition: 0.3s;
            text-decoration: none;
            font-weight: 500;
        }

            .nav-link:hover, .nav-link.active {
                opacity: 1;
                background: rgba(255,255,255,0.1);
                color: white;
            }

        .main-content {
            margin-left: 280px;
            flex-grow: 1;
            padding: 40px;
            width: calc(100% - 280px);
        }

        .user-header {
            text-align: center;
            padding: 40px 20px;
        }

        .avatar {
            width: 90px;
            height: 90px;
            background: #deeaf3;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            color: #6a96b3;
            font-size: 1.8rem;
            font-weight: bold;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .logout-container {
            margin-top: auto;
            padding: 20px;
        }

        .btn-logout {
            background-color: #2c5d7d;
            color: white;
            border: none;
            border-radius: 8px;
            width: 100%;
            padding: 10px;
            transition: 0.3s;
        }

            .btn-logout:hover {
                background-color: #1e425a;
                color: white;
            }
    </style>
</head>
<body>
    <div class="sidebar shadow-lg">
        <div class="user-header">
            <div class="avatar">
                @if (User.IsInRole("Gerente"))
                {
                    <span>GE</span>
                }
                else if (User.IsInRole("Especialista"))
                {
                    <span>ES</span>
                }
                else if (User.IsInRole("Fisioterapeuta"))
                {
                    <span>FT</span>
                }
            </div>
            <h6 class="mb-0 fw-bold">@(User.Identity.Name ?? "Usuario")</h6>
            <small class="opacity-75">
                @if (User.IsInRole("Gerente"))
                {
                    <text>Gerente</text>
                }
                else if (User.IsInRole("Especialista"))
                {

                    <text>Especialista</text>
                }
                else
                {

                    <text>Fisioterapeuta</text>
                }
            </small>
            <hr class="mt-4 opacity-25">
        </div>

        <nav class="nav flex-column">
            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-2"></i> Inicio</a>

            @if (User.IsInRole("Gerente"))
            {
                <a class="nav-link" asp-controller="Usuario" asp-action="Index"><i class="bi bi-people me-2"></i> Usuarios</a>
                <a class="nav-link" asp-controller="Paciente" asp-action="Index"><i class="bi bi-people me-2"></i> Pacientes</a>
                <a class="nav-link" asp-controller="Cita" asp-action="Index"><i class="bi bi-calendar-event me-2"></i> Citas</a>
                <a class="nav-link" asp-controller="Terapia" asp-action="Index"><i class="bi bi-briefcase me-2"></i> Servicios</a>
                <a class="nav-link" asp-controller="Caja" asp-action="Index"><i class="bi bi-cash-stack me-2"></i> Caja</a>
            }
            else if (User.IsInRole("Especialista"))
            {
                <a class="nav-link" asp-controller="Paciente" asp-action="Index"><i class="bi bi-people me-2"></i> Pacientes</a>
                <a class="nav-link" asp-controller="Cita" asp-action="Index"><i class="bi bi-calendar-event me-2"></i> Citas</a>
                <a class="nav-link" asp-controller="Terapia" asp-action="Index"><i class="bi bi-briefcase me-2"></i> Servicios</a>
                <a class="nav-link" asp-controller="Caja" asp-action="Index"><i class="bi bi-cash-stack me-2"></i> Caja</a>
            }
            else if (User.IsInRole("Fisioterapeuta"))
            {
                <a class="nav-link" asp-controller="Cita" asp-action="Index"><i class="bi bi-calendar-check me-2"></i> Mis citas</a>
            }
        </nav>

        <div class="logout-container">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn-logout">
                    Cerrar sesión
                </button>
            </form>
        </div>
    </div>

    <div class="main-content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>