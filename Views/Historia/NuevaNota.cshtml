@{
}
@model FisioterapiaWeb.Models.FichaClinica

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0" style="border-radius: 20px;">
                <div class="card-header bg-white border-0 pt-4 ps-4">
                    <h3 class="fw-bold mb-0" style="color: #2c5d7d;">
                        <i class="bi bi-journal-plus me-2"></i>Nueva Nota de Evolución
                    </h3>
                    <p class="text-muted">Paciente: <span class="fw-bold text-dark">@ViewBag.Nombre</span></p>
                </div>

                <div class="card-body p-4">
                    <form asp-action="GuardarNota" method="post">
                        <input type="hidden" name="PacienteId" value="@ViewBag.PacienteId" />
                        <input type="hidden" name="nombrePaciente" value="@ViewBag.Nombre" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Especialista</label>
                            <input type="text" asp-for="Especialista" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Diagnóstico</label>
                            <input type="text" asp-for="Diagnostico" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Motivo de Consulta</label>
                            <textarea asp-for="MotivoConsulta" class="form-control" rows="2" required></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Evolución y Tratamiento</label>
                            <textarea asp-for="Evolucion" class="form-control" rows="4" required></textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm" style="background-color: #2c5d7d; border-radius: 15px;">
                                <i class="bi bi-save me-2"></i>Guardar en Firebase
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>