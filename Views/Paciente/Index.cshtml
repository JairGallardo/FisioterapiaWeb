@model List<FisioterapiaWeb.Models.Paciente>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            <h1 class="fw-bold mb-0">Paciente</h1>
            <small class="text-muted">@Model.Count pacientes registrados</small>
        </div>
        <button class="btn btn-primary shadow-sm px-4" style="background-color: #2c5d7d; border-radius: 20px;" data-bs-toggle="modal" data-bs-target="#modalNuevoPaciente">
            <i class="bi bi-person-plus-fill me-2"></i> Nuevo paciente
        </button>
    </div>

    <div class="row my-4 align-items-center">
        <div class="col-md-7">
            <div class="input-group bg-white shadow-sm" style="border-radius: 15px; overflow: hidden;">
                <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="searchInput" class="form-control border-0 py-2" placeholder="Buscar por nombre o DNI...">
            </div>
        </div>
        <div class="col-md-5 text-end">
            <div class="btn-group shadow-sm" style="border-radius: 12px; overflow: hidden;">
                <button class="btn btn-secondary border-0 px-3" onclick="filterCards('all')">Todos</button>
                <button class="btn btn-secondary border-0 px-3" style="background-color: #4a7c92;" onclick="filterCards('Activo')">Activo</button>
                <button class="btn btn-secondary border-0 px-3" onclick="filterCards('Inactivo')">Inactivo</button>
            </div>
        </div>
    </div>

    <div class="row" id="pacientesGrid">
        @foreach (var p in Model)
        {
            <div class="col-md-4 mb-4 paciente-card" data-nombre="@p.Nombre @p.Apellido" data-dni="@p.Dni" data-status="Activo">
                <div class="card border-0 shadow-sm p-3" style="border-radius: 20px; background-color: #f8f9fa;">
                    <div class="d-flex align-items-start">
                        <div class="avatar-circle me-3" style="width: 50px; height: 50px; background: #e0e6ed; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #6a96b3; font-weight: bold; font-size: 1.2rem;">
                            @(p.Nombre?.Substring(0, 1))@(p.Apellido?.Substring(0, 1))
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between">
                                <h6 class="fw-bold mb-0">@p.Nombre @p.Apellido</h6>
                                <span class="badge bg-success-subtle text-success rounded-pill px-2" style="font-size: 0.7rem;">Activo</span>
                            </div>
                            <small class="text-muted d-block">DNI: @p.Dni</small>
                            <small class="text-muted d-block">Tel: @p.Telefono</small>

                            <div class="d-flex justify-content-end mt-3 gap-2">
                                <a asp-action="Editar" asp-route-id="@p.Id" class="btn btn-sm btn-dark rounded-circle d-flex align-items-center justify-content-center" style="background-color: #2c5d7d; width: 35px; height: 35px; border: none;">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>

                                <form asp-action="Eliminar" asp-route-id="@p.Id" method="post" onsubmit="return confirm('¿Eliminar este paciente?')">
                                    <button type="submit" class="btn btn-sm btn-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; border: none;">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="modalNuevoPaciente" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 25px;">
            <div class="modal-body p-4">
                <h3 class="fw-bold text-center mb-4">Nuevo paciente</h3>
                <form asp-action="Guardar" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre completo*</label>
                        <div class="row">
                            <div class="col">
                                <input type="text" name="Nombre" class="form-control bg-light border-0 py-2" placeholder="Nombre" required style="border-radius: 10px;">
                            </div>
                            <div class="col">
                                <input type="text" name="Apellido" class="form-control bg-light border-0 py-2" placeholder="Apellido" required style="border-radius: 10px;">
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Teléfono</label>
                            <div class="input-group">
                                <input type="text" name="Telefono" class="form-control bg-light border-0 py-2" placeholder="999..." style="border-radius: 10px 0 0 10px;">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-telephone"></i></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">DNI</label>
                            <input type="text" name="Dni" class="form-control bg-light border-0 py-2" placeholder="DNI" style="border-radius: 10px;">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Correo</label>
                        <input type="email" name="Correo" class="form-control bg-light border-0 py-2" placeholder="ejemplo@correo.com" style="border-radius: 10px;">
                    </div>
                    <div class="d-flex gap-3 mt-2">
                        <button type="button" class="btn btn-outline-primary w-100 py-2 fw-bold" data-bs-dismiss="modal" style="border-radius: 25px; color: #2c5d7d; border-color: #2c5d7d;">Cancelar</button>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow" style="border-radius: 25px; background-color: #2c5d7d; border: none;">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function () {
            let filter = this.value.toLowerCase();
            let cards = document.querySelectorAll('.paciente-card');

            cards.forEach(card => {
                let nombre = card.getAttribute('data-nombre').toLowerCase();
                let dni = card.getAttribute('data-dni').toLowerCase();
                card.style.display = (nombre.includes(filter) || dni.includes(filter)) ? "" : "none";
            });
        });

        function filterCards(status) {
            let cards = document.querySelectorAll('.paciente-card');
            cards.forEach(card => {
                card.style.display = (status === 'all' || card.getAttribute('data-status') === status) ? "" : "none";
            });
        }
    </script>
}