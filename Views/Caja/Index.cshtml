@model List<FisioterapiaWeb.Models.Transaccion>

<div class="container-fluid pt-4 px-5" style="background-color: #e9ecef; min-height: 100vh;">
    <div class="mb-5">
        <h1 class="display-5 fw-normal" style="color: #000; font-family: 'Georgia', serif;">Caja</h1>
        <p class="text-muted">Servicios disponibles en el centro</p>
    </div>

    <div class="mx-auto" style="max-width: 1100px;">
        <div class="row bg-white py-3 px-4 mb-3 shadow-sm align-items-center" style="border-radius: 12px;">
            <div class="col-3 text-center"><h4 class="mb-0 fw-normal">Servicio</h4></div>
            <div class="col-3 text-center"><h4 class="mb-0 fw-normal">Medio de pago</h4></div>
            <div class="col-3 text-center"><h4 class="mb-0 fw-normal">Paciente</h4></div>
            <div class="col-3 text-center"><h4 class="mb-0 fw-normal">Total</h4></div>
        </div>

        <div style="border-top: 3px solid #366d91; border-bottom: 3px solid #366d91; padding: 20px 0;">
            @foreach (var t in Model)
            {
                <div class="row bg-white py-3 px-4 mb-3 align-items-center shadow-sm" style="border-radius: 5px;">
                    <div class="col-3 text-center">
                        <span class="fw-bold" style="color: #333;">@t.Concepto</span>
                    </div>
                    <div class="col-3 text-center">
                        <span class="fw-bold" style="color: #333;">@t.MetodoPago</span>
                    </div>
                    <div class="col-3 text-center">
                        <span class="fw-bold" style="color: #333;">@t.PacienteNombre</span>
                    </div>
                    <div class="col-3 text-center">
                        <span class="fw-bold" style="color: #7ab397;">s/.@t.Monto.ToString("N2")</span>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-4 text-muted bg-white shadow-sm" style="border-radius: 5px;">
                    No hay registros disponibles.
                </div>
            }
        </div>
    </div>
</div>

<style>
    body {
        background-color: #e9ecef;
    }

    h1, h4 {
        font-family: 'Georgia', serif;
    }
</style>