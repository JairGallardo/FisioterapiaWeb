@{
}
@model FisioterapiaWeb.Models.Cita

<div class="container mt-4">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 600px; border-radius: 20px;">
        <div class="card-header bg-white border-0 pt-4 text-center">
            <h3 class="fw-bold" style="color: #2c5d7d;">Editar Cita</h3>
            <p class="text-muted">Actualiza los detalles de la programación</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="Actualizar" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="NombrePaciente" />
                <input type="hidden" asp-for="Lugar" />

                <div class="mb-3">
                    <label class="form-label fw-bold small">Paciente</label>
                    <select asp-for="PacienteId" class="form-select bg-light border-0 py-2" style="border-radius: 12px;" required>
                        @if (ViewBag.Pacientes != null)
                        {
                            @foreach (var p in (List<FisioterapiaWeb.Models.Paciente>)ViewBag.Pacientes)
                            {
                                <option value="@p.Id">@p.Nombre @p.Apellido</option>
                            }
                        }
                    </select>
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label fw-bold small">Fecha*</label>
                        <input asp-for="Fecha" type="date" class="form-control bg-light border-0 py-2" style="border-radius: 12px;" required />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold small">Hora*</label>
                        <input asp-for="Hora" type="time" class="form-control bg-light border-0 py-2" style="border-radius: 12px;" required />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label fw-bold small">Duración (min)</label>
                        <select asp-for="DuracionMinutos" class="form-select bg-light border-0 py-2" style="border-radius: 12px;">
                            <option value="30">30 min</option>
                            <option value="45">45 min</option>
                            <option value="60">60 min</option>
                            <option value="90">90 min</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold small">Especialista*</label>
                        <input asp-for="Especialista" class="form-control bg-light border-0 py-2" style="border-radius: 12px;" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small">Tratamiento / Servicio</label>
                    <select asp-for="Tratamiento" class="form-select bg-light border-0 py-2" style="border-radius: 12px;" required>
                        @if (ViewBag.Terapias != null)
                        {
                            @foreach (var t in (List<FisioterapiaWeb.Models.Terapia>)ViewBag.Terapias)
                            {
                                <option value="@t.Nombre">@t.Nombre</option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small">Estado de la Cita</label>
                    <select asp-for="Estado" class="form-select bg-light border-0 py-2 fw-bold" style="border-radius: 12px;">
                        <option value="Reservado">Reservado</option>
                        <option value="Completada">Completada</option>
                        <option value="Cancelada">Cancelada</option>
                        <option value="Incompleta">Incompleta</option>
                    </select>
                </div>

                <div class="d-flex gap-3">
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2" style="border-radius: 25px;">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary w-100 py-2 shadow" style="background-color: #2c5d7d; border-radius: 25px; border: none;">
                        Actualizar Cita
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>