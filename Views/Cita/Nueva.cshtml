@model FisioterapiaWeb.Models.Cita

<div class="container mt-4">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-white border-0 pt-4">
            <h3 class="fw-bold" style="color: #2c5d7d;">
                <i class="bi bi-calendar-event me-2"></i>Programar Cita
            </h3>
        </div>
        <div class="card-body">
            <form asp-controller="Cita" asp-action="Nueva" method="post">
                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted fw-bold small mb-1">Paciente</label>
                        <select asp-for="PacienteId" class="form-select form-select-custom text-secondary" required>
                            <option value="" disabled selected hidden>Seleccione un paciente...</option>
                            @if (ViewBag.Pacientes != null)
                            {
                                @foreach (var p in (List<FisioterapiaWeb.Models.Paciente>)ViewBag.Pacientes)
                                {
                                    <option value="@p.Id" class="text-dark">@p.Nombre @p.Apellido</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label text-muted fw-bold small mb-1">Fecha</label>
                        <input asp-for="Fecha" type="date" class="form-control form-select-custom text-dark" required />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label text-muted fw-bold small mb-1">Hora</label>
                        <input asp-for="Hora" type="time" class="form-control form-select-custom text-dark" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted fw-bold small mb-1">Especialista</label>
                        <select asp-for="Recepcionista" class="form-select form-select-custom text-secondary" required>
                            <option value="" disabled selected hidden>Nombre del fisioterapeuta</option>
                            @if (ViewBag.Usuarios != null)
                            {
                                @foreach (var p in (List<FisioterapiaWeb.Models.Usuario>)ViewBag.Usuarios)
                                {
                                    <option value="@p.Correo" class="text-dark">@p.NombreCompleto</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted fw-bold small mb-1">Tipo de Servicio</label>
                        <select asp-for="Tratamiento" class="form-select form-select-custom text-secondary" required>
                            <option value="" disabled selected hidden>Seleccione una terapia...</option>
                            @if (ViewBag.Terapias != null)
                            {
                                @foreach (var t in (List<FisioterapiaWeb.Models.Terapia>)ViewBag.Terapias)
                                {
                                    <option value="@t.Nombre" class="text-dark">@t.Nombre (S/ @t.Precio.ToString("F2"))</option>
                                }
                            }
                        </select>
                    </div>

                </div>

                <div class="mt-4 text-end">
                    <hr class="opacity-25" />
                    <a asp-action="Index" class="btn btn-light px-4 me-2" style="border-radius: 20px; font-size: 0.9rem;">Regresar</a>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm" style="background-color: #2c5d7d; border: none; border-radius: 20px; font-size: 0.9rem;">
                        <i class="bi bi-save me-2"></i>Guardar Cita
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-select-custom {
        border: 1px solid #dee2e6 !important;
        border-radius: 10px !important;
        padding: 0.65rem 2.5rem 0.65rem 1rem !important;
        font-size: 0.95rem !important;
        background-color: #fff !important;
        box-shadow: none !important;
        transition: border-color 0.2s ease-in-out;
    }

        .form-select-custom:focus {
            border-color: #2c5d7d !important;
        }
</style>