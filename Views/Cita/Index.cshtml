@model List<FisioterapiaWeb.Models.Cita>

<div class="container-fluid py-4" style="font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background-color: #f8fafc; min-height: 100vh;">
    @if (User.IsInRole("Fisioterapeuta") || User.IsInRole("Gerente") || User.IsInRole("Recepcionista"))
    {
        <div class="row mb-4">
            <div class="col-12 d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="fw-bold m-0" style="font-size: 1.8rem; color: #0f172a; letter-spacing: -0.5px;">Agenda</h1>
                    <p class="text-muted m-0" style="font-size: 0.9rem;">Gestiona las citas del centro</p>
                </div>
                @if (!User.IsInRole("Fisioterapeuta"))
                {
                    <button class="btn text-white px-4 py-2 shadow-sm fw-semibold d-flex align-items-center transition-all" data-bs-toggle="modal" data-bs-target="#modalNuevaCita" style="background-color: #2c5d7d; border-radius: 12px; font-size: 0.9rem; border: none;">
                        <i class="bi bi-calendar-plus me-2" style="font-size: 1rem;"></i>Nueva Cita
                    </button>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; background-color: #ffffff;">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-3 px-2">
                    <button class="btn btn-link text-secondary p-1 hover-bg-light rounded-circle" style="width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center;"><i class="bi bi-chevron-left fs-6"></i></button>
                    <span class="fw-bold text-capitalize" style="font-size: 1rem; color: #1e293b;">@DateTime.Now.ToString("MMMM 'de' yyyy")</span>
                    <button class="btn btn-link text-secondary p-1 hover-bg-light rounded-circle" style="width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center;"><i class="bi bi-chevron-right fs-6"></i></button>
                </div>

                <div class="d-flex justify-content-between align-items-center overflow-auto pb-1 gap-2" style="scrollbar-width: none;">
                    @{
                        string[] dias = { "Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom" };
                        DateTime inicioSemana = DateTime.Now.AddDays(-(int)DateTime.Now.DayOfWeek + 1);
                    }
                    @for (int i = 0; i < 7; i++)
                    {
                        var diaFecha = inicioSemana.AddDays(i);
                        bool esHoy = diaFecha.Date == DateTime.Today.Date;
                        <div class="col dia-selector d-flex flex-column align-items-center py-2 px-3 @(esHoy ? "active-day" : "")"
                             data-fecha="@diaFecha.ToString("yyyy-MM-dd")"
                             style="cursor: pointer; transition: all 0.2s; min-width: 55px; border-radius: 12px;">
                            <small class="fw-semibold mb-1 text-uppercase" style="font-size: 0.75rem; color: @(esHoy ? "#2c5d7d" : "#94a3b8");">@dias[i]</small>
                            <span class="fw-bold n-dia" style="font-size: 1.1rem; color: @(esHoy ? "#2c5d7d" : "#334155");">@diaFecha.Day</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <h5 id="fecha-seleccionada-titulo" class="fw-bold mb-3 text-capitalize" style="font-size: 1rem; color: #64748b;">
            @DateTime.Now.ToString("dddd, d 'de' MMMM")
        </h5>

        <div class="row" id="contenedor-citas">
            @if (Model != null && Model.Any())
            {
                @foreach (var cita in Model)
                {
                    <div class="col-12 mb-3 tarj-cita" id="cita-@cita.Id">
                        <div class="card border-0 shadow-sm transition-hover" style="border-radius: 16px; background-color: #ffffff;">
                            <div class="card-body d-flex align-items-center p-3">
                                <div class="text-center border-end pe-4" style="min-width: 100px;">
                                    <h4 class="mb-0 fw-bold" style="font-size: 1.3rem; color: #0f172a;">@cita.Hora</h4>
                                    <small class="text-muted fw-medium" style="font-size: 0.8rem;">@cita.DuracionMinutos min</small>
                                </div>

                                <div class="ps-4 flex-grow-1">
                                    <h5 class="fw-bold mb-1" style="font-size: 1.05rem; color: #0f172a;">@cita.NombrePaciente</h5>
                                    <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                                        <span class="text-secondary fw-medium" style="font-size: 0.9rem;">@cita.Tratamiento</span>
                                        <span class="badge fw-semibold px-2 py-1" style="background-color: #eef7fc; color: #2c5d7d; border-radius: 6px; font-size: 0.75rem;">1/10</span>
                                    </div>
                                    <div class="d-flex align-items-center text-muted" style="font-size: 0.8rem;">
                                        <i class="bi bi-person-circle me-1.5" style="color: #94a3b8;"></i>
                                        <span class="fw-medium">@cita.Recepcionista</span>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center gap-3">
                                    <div class="badge-estado-container">
                                        @if (cita.Estado == "Completada")
                                        {
                                            <span class="badge px-3 py-2 fw-semibold" style="background-color: #e8f5e9; color: #2e7d32; border-radius: 50px; font-size: 0.8rem; min-width: 100px;">Completada</span>
                                        }
                                        else if (cita.Estado == "Incompleta" || cita.Estado == "Faltó")
                                        {
                                            <span class="badge px-3 py-2 fw-semibold" style="background-color: #ffebee; color: #c62828; border-radius: 50px; font-size: 0.8rem; min-width: 100px;">Faltó</span>
                                        }
                                        else
                                        {
                                            <span class="badge px-3 py-2 fw-semibold" style="background-color: #f1f5f9; color: #64748b; border-radius: 50px; font-size: 0.8rem; min-width: 100px;">Pendiente</span>
                                        }
                                    </div>

                                    <div class="dropdown">
                                        <button class="btn btn-light rounded-circle p-0 d-flex align-items-center justify-content-center border-0 shadow-none" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 36px; height: 36px; background-color: #f1f5f9;">
                                            <i class="bi bi-three-dots-vertical text-secondary" style="font-size: 1rem;"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2 mt-1" style="border-radius: 12px; min-width: 180px;">
                                            @if (User.IsInRole("Recepcionista"))
                                            {
                                                <li>
                                                    <a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" asp-action="Editar" asp-route-id="@cita.Id">
                                                        <i class="bi bi-pencil-fill text-warning me-2"></i> Editar
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider opacity-25"></li>
                                                <li>
                                                    <a class="dropdown-item py-2 rounded-2 text-danger fw-medium" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="eliminarCita('@cita.Id')">
                                                        <i class="bi bi-trash-fill me-2"></i> Eliminar
                                                    </a>
                                                </li>
                                            }
                                            else if (User.IsInRole("Fisioterapeuta"))
                                            {
                                                <li>
                                                    <a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" asp-controller="Historia" asp-action="Index" asp-route-pacienteId="@cita.PacienteId" asp-route-nombre="@cita.NombrePaciente">
                                                        <i class="bi bi-file-earmark-medical text-primary me-2"></i> Historial Clínico
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider opacity-25"></li>
                                                <li>
                                                    <a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="cambiarEstadoCita('@cita.Id', 'Completada')">
                                                        <i class="bi bi-check-circle-fill text-success me-2"></i> Completado
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="cambiarEstadoCita('@cita.Id', 'Faltó')">
                                                        <i class="bi bi-x-circle-fill text-danger me-2"></i> Faltó
                                                    </a>
                                                </li>
                                            }
                                            else if (User.IsInRole("Gerente"))
                                            {
                                                <li>
                                                    <a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" asp-controller="Historia" asp-action="Index" asp-route-pacienteId="@cita.PacienteId" asp-route-nombre="@cita.NombrePaciente">
                                                        <i class="bi bi-file-earmark-medical text-primary me-2"></i> Llenar Historial
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider opacity-25"></li>
                                                <li>
                                                    <a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="cambiarEstadoCita('@cita.Id', 'Completada')">
                                                        <i class="bi bi-check-circle-fill text-success me-2"></i> Completada
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="cambiarEstadoCita('@cita.Id', 'Faltó')">
                                                        <i class="bi bi-x-circle-fill text-danger me-2"></i> Faltó
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" asp-action="Editar" asp-route-id="@cita.Id">
                                                        <i class="bi bi-pencil-fill text-warning me-2"></i> Editar
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider opacity-25"></li>
                                                <li>
                                                    <a class="dropdown-item py-2 rounded-2 text-danger fw-medium" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="eliminarCita('@cita.Id')">
                                                        <i class="bi bi-trash-fill me-2"></i> Eliminar
                                                    </a>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center p-5">
                    <p class="text-muted fw-medium">No hay citas programadas.</p>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="modalNuevaCita" tabindex="-1" aria-labelledby="modalNuevaCitaLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-0 pt-4 px-4 pb-2">
                <h4 class="fw-bold m-0" id="modalNuevaCitaLabel" style="color: #2c5d7d; font-family: system-ui;">
                    <i class="bi bi-calendar-plus me-2"></i>Nueva Cita
                </h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 pb-4 pt-2">
                <form asp-controller="Cita" asp-action="Nueva" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary" style="font-size: 0.85rem;">Paciente</label>
                            <select name="PacienteId" class="form-select" style="border-radius: 8px; font-size: 0.9rem;" required>
                                <option value="">Seleccione un paciente...</option>
                                @if (ViewBag.Pacientes != null)
                                {
                                    @foreach (var p in (List<FisioterapiaWeb.Models.Paciente>)ViewBag.Pacientes)
                                    {
                                        <option value="@p.Id">@p.Nombre @p.Apellido</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold text-secondary" style="font-size: 0.85rem;">Fecha</label>
                            <input id="txtFechaCita" name="Fecha" type="date" class="form-control" style="border-radius: 8px; font-size: 0.9rem;" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold text-secondary" style="font-size: 0.85rem;">Hora</label>
                            <input name="Hora" type="time" class="form-control" style="border-radius: 8px; font-size: 0.9rem;" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary" style="font-size: 0.85rem;">Especialista</label>
                            <input name="Especialista" class="form-control" style="border-radius: 8px; font-size: 0.9rem;" placeholder="Nombre del fisioterapeuta" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary" style="font-size: 0.85rem;">Tipo de Servicio</label>
                            <select id="ddlTratamiento" name="Tratamiento" class="form-select" style="border-radius: 8px; font-size: 0.9rem;" required>
                                <option value="">Seleccione una terapia...</option>
                                @if (ViewBag.Terapias != null)
                                {
                                    @foreach (var t in (List<FisioterapiaWeb.Models.Terapia>)ViewBag.Terapias)
                                    {
                                        <option value="@t.Nombre" data-precio="@t.Precio">@t.Nombre</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-12 my-2"><hr class="text-muted opacity-25"></div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold text-secondary" style="font-size: 0.85rem;">Número de Sesión</label>
                            <input id="txtNumeroSesion" name="NumeroSesion" class="form-control" style="border-radius: 8px; font-size: 0.9rem;" placeholder="Ej: 1/1 o 2/10" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold text-secondary" style="font-size: 0.85rem;">Método de Pago</label>
                            <select name="MetodoPago" class="form-select" style="border-radius: 8px; font-size: 0.9rem;" required>
                                <option value="Efectivo">Efectivo</option>
                                <option value="Yape">Yape</option>
                                <option value="Plin">Plin</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold text-secondary" style="font-size: 0.85rem;">Monto (S/)</label>
                            <input id="txtMonto" name="Monto" type="number" step="0.01" class="form-control" style="border-radius: 8px; font-size: 0.9rem;" required />
                        </div>
                    </div>
                    <div class="mt-4 text-end">
                        <button type="button" class="btn btn-light px-4 me-2 fw-semibold" data-bs-dismiss="modal" style="border-radius: 8px; font-size: 0.9rem;">Cancelar</button>
                        <button type="submit" class="btn text-white px-4 shadow-sm fw-semibold" style="background-color: #2c5d7d; border-radius: 8px; font-size: 0.9rem;">
                            <i class="bi bi-calendar-check me-2"></i>Agendar Cita
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEliminarConfirmar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 380px;">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-body text-center p-4">
                <h5 class="fw-bold mb-4" style="color: #0f172a;">¿Estás seguro de eliminar esta cita?</h5>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light px-4 py-2 fw-semibold" data-bs-dismiss="modal" style="border-radius: 8px; font-size: 0.9rem;">Cancelar</button>
                    <button type="button" id="btnConfirmarEliminarCita" class="btn text-white px-4 py-2 fw-semibold" style="background-color: #e11d48; border-radius: 8px; font-size: 0.9rem;">Eliminar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .dia-selector:hover {
        background-color: #f1f5f9;
    }

    .active-day {
        background-color: #eef7fc !important;
        border: 1px solid rgba(44, 93, 125, 0.15);
    }

    .transition-hover {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .transition-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
        }

    .hover-bg-light:hover {
        background-color: #f1f5f9;
        color: #0f172a !important;
    }
</style>

@section Scripts {
    <script>

        const esRecepcionista = @(User.IsInRole("Recepcionista") ? "true" : "false");
        const esGerente = @(User.IsInRole("Gerente") ? "true" : "false");
        const esFisioterapeuta = @(User.IsInRole("Fisioterapeuta") ? "true" : "false");

        let citaIdAEliminar = null;
        const modalEliminar = new bootstrap.Modal(document.getElementById('modalEliminarConfirmar'));

        document.addEventListener("DOMContentLoaded", function () {
            const modalNuevaCita = document.getElementById('modalNuevaCita');
            if (modalNuevaCita) {
                modalNuevaCita.addEventListener('show.bs.modal', function () {
                    const txtFecha = document.getElementById('txtFechaCita');
                    if (txtFecha && !txtFecha.value) {
                        const hoy = new Date();
                        const year = hoy.getFullYear();
                        const month = String(hoy.getMonth() + 1).padStart(2, '0');
                        const day = String(hoy.getDate()).padStart(2, '0');
                        txtFecha.value = `${year}-${month}-${day}`;
                    }
                });
            }

            const ddlTratamiento = document.getElementById('ddlTratamiento');
            const txtNumeroSesion = document.getElementById('txtNumeroSesion');
            const txtMonto = document.getElementById('txtMonto');

            if (ddlTratamiento) {
                ddlTratamiento.addEventListener('change', function () {
                    const opcionSeleccionada = this.options[this.selectedIndex];
                    const nombreServicio = this.value.toLowerCase().trim();
                    const precioBase = opcionSeleccionada.getAttribute('data-precio');

                    if (nombreServicio === "terapia basica" || nombreServicio === "terapia básica") {
                        txtNumeroSesion.value = "1/1";
                        txtNumeroSesion.readOnly = true;
                        txtMonto.value = precioBase ? parseFloat(precioBase).toFixed(2) : "0.00";
                        txtMonto.readOnly = true;
                    } else {
                        txtNumeroSesion.value = "";
                        txtNumeroSesion.placeholder = "Ej: 2/10";
                        txtNumeroSesion.readOnly = false;
                        txtMonto.value = precioBase ? parseFloat(precioBase).toFixed(2) : "";
                        txtMonto.readOnly = false;
                    }
                });
            }

            document.querySelectorAll('.dia-selector').forEach(item => {
                item.addEventListener('click', function () {
                    document.querySelectorAll('.dia-selector').forEach(d => d.classList.remove('active-day'));
                    this.classList.add('active-day');

                    const fechaSeleccionada = this.getAttribute('data-fecha');
                    const opciones = { weekday: 'long', day: 'numeric', month: 'long' };
                    const fechaDate = new Date(fechaSeleccionada + 'T00:00:00');
                    document.getElementById('fecha-seleccionada-titulo').innerText = fechaDate.toLocaleDateString('es-ES', opciones);

                    cargarCitasPorFecha(fechaSeleccionada);
                });
            });

            document.getElementById('btnConfirmarEliminarCita').addEventListener('click', function() {
                if(citaIdAEliminar) {
                    fetch(`/Cita/Eliminar?id=${citaIdAEliminar}`, {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(res => res.json())
                    .then(data => {
                        if(data.success) {
                            modalEliminar.hide();
                            const elementoCita = document.getElementById(`cita-${citaIdAEliminar}`);
                            if(elementoCita) elementoCita.remove();
                            verificarContenedorVacio();
                        }
                    });
                }
            });
        });

        function cargarCitasPorFecha(fecha) {
            const contenedor = document.getElementById('contenedor-citas');
            contenedor.innerHTML = '<div class="col-12 text-center p-5"><div class="spinner-border text-secondary" role="status"></div></div>';

            fetch(`/Cita/ObtenerCitasPorFecha?fecha=${fecha}`)
                .then(res => res.json())
                .then(citas => {
                    contenedor.innerHTML = '';
                    if (citas.length === 0) {
                        contenedor.innerHTML = '<div class="col-12 text-center p-5"><p class="text-muted fw-medium">No hay citas programadas.</p></div>';
                        return;
                    }

                    citas.forEach(cita => {
                        let badgeHtml = '';
                        if (cita.estado === "Completada") {
                            badgeHtml = `<span class="badge px-3 py-2 fw-semibold" style="background-color: #e8f5e9; color: #2e7d32; border-radius: 50px; font-size: 0.8rem; min-width: 100px;">Completada</span>`;
                        } else if (cita.estado === "Incompleta" || cita.estado === "Faltó") {
                            badgeHtml = `<span class="badge px-3 py-2 fw-semibold" style="background-color: #ffebee; color: #c62828; border-radius: 50px; font-size: 0.8rem; min-width: 100px;">Faltó</span>`;
                        } else {
                            badgeHtml = `<span class="badge px-3 py-2 fw-semibold" style="background-color: #f1f5f9; color: #64748b; border-radius: 50px; font-size: 0.8rem; min-width: 100px;">Pendiente</span>`;
                        }

                let opcionesMenuHtml = '';
                if (esRecepcionista) {
                    opcionesMenuHtml = `
                        <li><a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="/Cita/Editar/${cita.id}"><i class="bi bi-pencil-fill text-warning me-2"></i> Editar</a></li>
                        <li><hr class="dropdown-divider opacity-25"></li>
                        <li><a class="dropdown-item py-2 rounded-2 text-danger fw-medium" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="eliminarCita('${cita.id}')"><i class="bi bi-trash-fill me-2"></i> Eliminar</a></li>
                    `;
                } else if (esFisioterapeuta) {
                    opcionesMenuHtml = `
                        <li><a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="/Historia/Index?pacienteId=${cita.pacienteId}&nombre=${encodeURIComponent(cita.nombrePaciente)}"><i class="bi bi-file-earmark-medical text-primary me-2"></i> Historial Clínico</a></li>
                        <li><hr class="dropdown-divider opacity-25"></li>
                        <li><a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="cambiarEstadoCita('${cita.id}', 'Completada')"><i class="bi bi-check-circle-fill text-success me-2"></i> Completado</a></li>
                        <li><a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="cambiarEstadoCita('${cita.id}', 'Faltó')"><i class="bi bi-x-circle-fill text-danger me-2"></i> Faltó</a></li>
                    `;
                } else if (esGerente) {
                    opcionesMenuHtml = `
                        <li><a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="/Historia/Index?pacienteId=${cita.pacienteId}&nombre=${encodeURIComponent(cita.nombrePaciente)}"><i class="bi bi-file-earmark-medical text-primary me-2"></i> Llenar Historial</a></li>
                        <li><hr class="dropdown-divider opacity-25"></li>
                        <li><a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="cambiarEstadoCita('${cita.id}', 'Completada')"><i class="bi bi-check-circle-fill text-success me-2"></i> Completada</a></li>
                        <li><a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="cambiarEstadoCita('${cita.id}', 'Faltó')"><i class="bi bi-x-circle-fill text-danger me-2"></i> Faltó</a></li>
                        <li><a class="dropdown-item py-2 rounded-2 fw-medium text-dark" style="font-size: 0.85rem;" href="/Cita/Editar/${cita.id}"><i class="bi bi-pencil-fill text-warning me-2"></i> Editar</a></li>
                        <li><hr class="dropdown-divider opacity-25"></li>
                        <li><a class="dropdown-item py-2 rounded-2 text-danger fw-medium" style="font-size: 0.85rem;" href="javascript:void(0);" onclick="eliminarCita('${cita.id}')"><i class="bi bi-trash-fill me-2"></i> Eliminar</a></li>
                    `;
                }

                        const tarjeta = `
                            <div class="col-12 mb-3 tarj-cita" id="cita-${cita.id}">
                                <div class="card border-0 shadow-sm transition-hover" style="border-radius: 16px; background-color: #ffffff;">
                                    <div class="card-body d-flex align-items-center p-3">
                                        <div class="text-center border-end pe-4" style="min-width: 100px;">
                                            <h4 class="mb-0 fw-bold" style="font-size: 1.3rem; color: #0f172a;">${cita.hora}</h4>
                                            <small class="text-muted fw-medium" style="font-size: 0.8rem;">${cita.duracionMinutos} min</small>
                                        </div>
                                        <div class="ps-4 flex-grow-1">
                                            <h5 class="fw-bold mb-1" style="font-size: 1.05rem; color: #0f172a;">${cita.nombrePaciente}</h5>
                                            <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                                                <span class="text-secondary fw-medium" style="font-size: 0.9rem;">${cita.tratamiento}</span>
                                                <span class="badge fw-semibold px-2 py-1" style="background-color: #eef7fc; color: #2c5d7d; border-radius: 6px; font-size: 0.75rem;">1/10</span>
                                            </div>
                                            <div class="d-flex align-items-center text-muted" style="font-size: 0.8rem;">
                                                <i class="bi bi-person-circle me-1.5" style="color: #94a3b8;"></i>
                                                <span class="fw-medium">${cita.especialista}</span>
                                            </div>
                                        </div>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="badge-estado-container">${badgeHtml}</div>
                                            <div class="dropdown">
                                                <button class="btn btn-light rounded-circle p-0 d-flex align-items-center justify-content-center border-0 shadow-none" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 36px; height: 36px; background-color: #f1f5f9;">
                                                    <i class="bi bi-three-dots-vertical text-secondary" style="font-size: 1rem;"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2 mt-1" style="border-radius: 12px; min-width: 180px;">
                                                    ${opcionesMenuHtml}
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>`;
                        contenedor.insertAdjacentHTML('beforeend', tarjeta);
                    });
                })
                .catch(() => {
                    contenedor.innerHTML = '<div class="col-12 text-center p-5 text-danger"><p>Error al cargar las citas.</p></div>';
                });
        }

        function cambiarEstadoCita(id, nuevoEstado) {
            fetch(`/Cita/CambiarEstado?id=${id}&nuevoEstado=${nuevoEstado}`, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const contenedorTarjeta = document.getElementById(`cita-${id}`);
                    if (contenedorTarjeta) {
                        const badgeContainer = contenedorTarjeta.querySelector('.badge-estado-container');
                        if (nuevoEstado === "Completada") {
                            badgeContainer.innerHTML = `<span class="badge px-3 py-2 fw-semibold" style="background-color: #e8f5e9; color: #2e7d32; border-radius: 50px; font-size: 0.8rem; min-width: 100px;">Completada</span>`;
                        } else if (nuevoEstado === "Faltó") {
                            badgeContainer.innerHTML = `<span class="badge px-3 py-2 fw-semibold" style="background-color: #ffebee; color: #c62828; border-radius: 50px; font-size: 0.8rem; min-width: 100px;">Faltó</span>`;
                        }
                    }
                }
            });
        }
        function completarCitaDesdeModal(id) {
            const pago = document.getElementById('ddlMetodoPago').value;
            const total = document.getElementById('txtTotalCobro').value;

            fetch(`/Cita/CambiarEstado?id=${id}&nuevoEstado=Completada&metodo=${pago}&monto=${total}`)
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                }
            });
        }

        function eliminarCita(id) {
            citaIdAEliminar = id;
            modalEliminar.show();
        }

        function verificarContenedorVacio() {
            const contenedor = document.getElementById('contenedor-citas');
            if (contenedor.querySelectorAll('.tarj-cita').length === 0) {
                contenedor.innerHTML = '<div class="col-12 text-center p-5"><p class="text-muted fw-medium">No hay citas programadas.</p></div>';
            }
        }
    </script>
}